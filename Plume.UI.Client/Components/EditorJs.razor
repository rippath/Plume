@using System.Text.Json
@using Plume.UI.Client.Models
@inject IJSRuntime JS

<div dir="@TextDirection">
    <MudCard Elevation="2">
        <MudCardContent>
            <div id="@EditorId" class="editorjs-root"></div>
        </MudCardContent>
        @if (!ReadOnly)
        {
            <MudCardActions Class="d-flex justify-end">
                <MudButton
                    Class="ml-1"
                    Variant="Variant.Text"
                    Color="Color.Secondary"
                    StartIcon="@Icons.Material.Outlined.Visibility"
                    OnClick="RequestPreviewAsync">
                    ޕްރިވިއު
                </MudButton>
                <MudButton
                    Class="ml-1"
                    Variant="Variant.Outlined"
                    Color="Color.Success"
                    OnClick="SaveAsync">
                    ރައްކާ ކުރޭ
                </MudButton>
                <MudButton
                    Variant="Variant.Outlined"
                    Color="Color.Error"
                    OnClick="SaveAsync">
                    ދެން ނޫޅެން
                </MudButton>
            </MudCardActions>
        }
    </MudCard>
</div>

@code {
    [Parameter] public string EditorId { get; set; } = $"editorjs-{Guid.NewGuid():N}";
    [Parameter] public object? Config { get; set; }
    [Parameter] public bool ReadOnly { get; set; }
    [Parameter] public EventCallback<string> OnSavedJson { get; set; }
    [Parameter] public EventCallback<string> OnPreviewRequested { get; set; }

    private bool _initialized;

    private string TextDirection
    {
        get
        {
            var config = Config as EditorJsConfig;
            var isRtl = config?.I18n?.Direction == "rtl" || config?.RightToLeft == true;
            return isRtl ? "rtl" : "ltr";
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_initialized)
        {
            await JS.InvokeVoidAsync("editorJsInterop.init", EditorId, Config ?? new { });
            if (!ReadOnly)
                await JS.InvokeVoidAsync("dhivehi.setupDhivehiEditor", EditorId);
            _initialized = true;
        }
    }

    public async Task<string> GetJsonAsync()
    {
        var result = await JS.InvokeAsync<object>("editorJsInterop.save", EditorId);
        return JsonSerializer.Serialize(result, new JsonSerializerOptions { WriteIndented = false });
    }

    public async Task SaveAsync()
    {
        try
        {
            var json = await GetJsonAsync();
            await OnSavedJson.InvokeAsync(json);
            Console.WriteLine("Saved editor data: " + json);
        }
        catch (JSException jex)
        {
            Console.Error.WriteLine("Error saving editor: " + jex.Message);
        }
    }

    private async Task RequestPreviewAsync()
    {
        try
        {
            var json = await GetJsonAsync();
            await OnPreviewRequested.InvokeAsync(json);
        }
        catch (JSException jex)
        {
            Console.Error.WriteLine("Error getting editor data for preview: " + jex.Message);
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (_initialized)
        {
            await JS.InvokeVoidAsync("editorJsInterop.destroy", EditorId);
        }
    }
}
