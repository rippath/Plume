@using Contract.Responses.Articles
@using MudBlazor
@using Plume.UI.Client.Helpers

@if (Articles.Count == 0)
{
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-4">@EmptyText</MudText>
}
else
{
    <MudGrid>
        @foreach (var article in Articles)
        {
            <MudItem xs="12" sm="6" md="4" Style="display: flex;">
                <MudCard Elevation="0" Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1); display: flex; flex-direction: column; width: 100%;">
                    @if (!string.IsNullOrEmpty(article.FeaturedImageUrl))
                    {
                        <MudCardMedia Image="@article.FeaturedImageUrl" Height="140" Style="border-radius: 16px 16px 0 0; flex-shrink: 0;" />
                    }
                    <MudCardContent Style="flex: 1;">
                        <MudText Typo="Typo.h6" Style="font-weight: 700; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                            @(string.IsNullOrWhiteSpace(article.Title) ? "(ސުރުހީ ނެތް)" : article.Title)
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                            @GetDateLabel(article)
                        </MudText>
                    </MudCardContent>
                    <MudCardActions Style="flex-shrink: 0; flex-wrap: wrap; gap: 4px;">
                        <MudButton Variant="Variant.Text" Color="Color.Primary"
                                   Href="@($"/editor/{article.Id}")"
                                   Style="border-radius: 999px;">އިސްލާހުކުރައްވާ</MudButton>

                        @if (article.Status is "Draft" or "Unlisted")
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Success"
                                       OnClick="@(() => OnPublish.InvokeAsync(article.Id))"
                                       Style="border-radius: 999px;">ޝާއިއުކުރައްވާ</MudButton>
                        }

                        @if (article.Status == "Published")
                        {
                            <MudButton Variant="Variant.Text" Color="Color.Warning"
                                       OnClick="@(() => OnUnlist.InvokeAsync(article.Id))"
                                       Style="border-radius: 999px;">އަންލިސްޓުކުރައްވާ</MudButton>
                        }

                        <MudButton Variant="Variant.Text" Color="Color.Error"
                                   OnClick="@(() => OnDelete.InvokeAsync(article.Id))"
                                   Style="border-radius: 999px;">ޑިލީޓުކުރައްވާ</MudButton>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@code {

    [Parameter, EditorRequired] public List<ArticleResponse> Articles { get; set; } = [];
    [Parameter] public string EmptyText { get; set; } = "ލިޔުމެއް ނެތް.";
    [Parameter] public EventCallback<Guid> OnPublish { get; set; }
    [Parameter] public EventCallback<Guid> OnUnlist { get; set; }
    [Parameter] public EventCallback<Guid> OnDelete { get; set; }

    private string GetDateLabel(ArticleResponse article)
    {
        if (article.Status == "Published" && article.PublishedAt.HasValue)
            return $"ޝާއިއުކުރީ: {DhivehiDateHelper.Format(article.PublishedAt.Value)}";

        return article.UpdatedDate.HasValue
            ? $"އަދާހަމަ: {DhivehiDateHelper.Format(article.UpdatedDate.Value)}"
            : string.Empty;
    }

}
