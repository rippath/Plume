@using Plume.UI.Client.Contracts.Local
@using Microsoft.AspNetCore.Components.Authorization
@inherits LayoutComponentBase
@inject NavigationManager NavigationManager
@inject IClientAuthService AuthService
@inject IThemePreferenceService ThemePreferenceService
@inject AuthenticationStateProvider AuthStateProvider

@if (!_authChecked)
{
    <MudRTLProvider RightToLeft="true">
        <MudThemeProvider Theme="@_theme" @bind-IsDarkMode="@_isDarkMode" />
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Style="position:fixed;top:0;left:0;right:0;z-index:9999;" />
    </MudRTLProvider>
}
else
{
<MudRTLProvider RightToLeft="true">
    <MudThemeProvider Theme="@_theme" @bind-IsDarkMode="@_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <MudLayout>
        <MudAppBar Fixed="true" Dense="true" Elevation="0" Class="main-appbar">
            <MudIconButton Icon="@LucideIcons.Menu" Color="Color.Inherit" OnClick="@DrawerToggle" />

            <MudText Typo="Typo.h5" Class="ml-3" Color="Color.Inherit" Style="font-weight: 800; letter-spacing: -0.5px;">ފަތްތޫރަ</MudText>

            <MudSpacer />

            <MudTextField @bind-Value="_searchQuery"
                          Placeholder="ހޯދާ"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          Adornment="Adornment.End"
                          AdornmentIcon="@LucideIcons.Search"
                          OnAdornmentClick="Search"
                          Style="border-radius: 999px;" />

            <MudTooltip Text="Toggle light/dark theme">
                <MudIconButton Icon="@(_isDarkMode ? LucideIcons.Sun : LucideIcons.Moon)"
                               Color="Color.Inherit" OnClick="ToggleDarkMode" />
            </MudTooltip>

            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@LucideIcons.User" Color="Color.Inherit" Dense="true">
                        <MudMenuItem Href="/profile/me">ޕްރޮފައިލް ބައްލަވާ</MudMenuItem>
                        <MudMenuItem Href="/settings">ސެޓިންގްސް</MudMenuItem>
                        <MudMenuItem OnClick="HandleLogout">ސައިން-އައުޓް</MudMenuItem>
                    </MudMenu>
                </Authorized>
                <NotAuthorized>
                    <MudMenu Icon="@LucideIcons.User" Color="Color.Inherit" Dense="true">
                        <MudMenuItem Href="/register">ރަޖިސްޓްރީ ކުރައްވާ</MudMenuItem>
                        <MudMenuItem Href="/login">ސައިން-އިން ކުރައްވާ</MudMenuItem>
                    </MudMenu>
                </NotAuthorized>
            </AuthorizeView>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="0">
            <NavMenu />
        </MudDrawer>

        <MudMainContent Class="pt-16 px-8">
            @Body
        </MudMainContent>
    </MudLayout>
</MudRTLProvider>
}

<style>
    /* ── Rounded interface overrides ── */
    .mud-card {
        border-radius: 16px !important;
    }

    .mud-paper:not(.mud-appbar):not(.mud-drawer-paper) {
        border-radius: 16px !important;
    }

    .mud-chip {
        border-radius: 999px !important;
    }

    .mud-input-outlined .mud-input-slot {
        border-radius: 12px !important;
    }

    .mud-input-outlined-border {
        border-radius: 12px !important;
    }

    .mud-button-root.mud-button {
        border-radius: 999px !important;
    }

    .mud-icon-button {
        border-radius: 50% !important;
    }

    /* AppBar subtle separator */
    .main-appbar {
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(128, 128, 128, 0.1);
    }

    /* Drawer polish */
    .mud-drawer-paper {
        border-radius: 0 !important;
        border-right: 1px solid rgba(128, 128, 128, 0.08) !important;
    }
</style>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode;
    private bool _authChecked;
    private string _searchQuery = "";
    private MudTheme _theme = new();

    protected override void OnInitialized()
    {
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = "#594AE2",
                AppbarBackground = "rgba(255,255,255,0.85)",
                Background = "#f7f7fb",
                Surface = "#ffffff",
                DrawerBackground = "#ffffff",
            },
            PaletteDark = new PaletteDark
            {
                Primary = "#776be7",
                AppbarBackground = "rgba(22,22,36,0.85)",
                Background = "#16161e",
                Surface = "#1e1e2d",
                DrawerBackground = "#1e1e2d",
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = new[] { "MV Typewriter", "Ak Rasmee" }
                }
            }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _isDarkMode = await ThemePreferenceService.GetDarkModeAsync();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
        {
            var returnUrl = Uri.EscapeDataString(NavigationManager.Uri);
            NavigationManager.NavigateTo($"/login?returnUrl={returnUrl}");
            return;
        }

        _authChecked = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.CheckOAuthCallbackAsync();
        }
    }

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await ThemePreferenceService.SetDarkModeAsync(_isDarkMode);
    }

    private void Search()
    {
        if (!string.IsNullOrWhiteSpace(_searchQuery))
        {
            NavigationManager.NavigateTo($"/search/{_searchQuery}");
        }
    }

    private async Task HandleLogout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/");
    }
}