@using Plume.UI.Client.Contracts.Local
@inherits LayoutComponentBase
@inject IThemePreferenceService ThemePreferenceService
@inject NavigationManager NavigationManager

<MudRTLProvider RightToLeft="true">
    <MudThemeProvider Theme="@_theme" @bind-IsDarkMode="@_isDarkMode" />
    <MudPopoverProvider />
    <MudDialogProvider />
    <MudSnackbarProvider />

    <div class="auth-root" style="background: @(_isDarkMode ? "#1e1e2d" : "#f5f5f5"); min-height: 100vh;">

        <!-- Minimal top bar -->
        <div class="auth-topbar">
            <MudText Typo="Typo.h6"
                     Style="font-weight: 800; color: #594AE2; cursor: pointer;"
                     @onclick='() => NavigationManager.NavigateTo("/")'>
                ފަތްތޫރަ
            </MudText>
            <MudTooltip Text="Theme Toggle">
                <MudIconButton Icon="@(_isDarkMode ? LucideIcons.Sun : LucideIcons.Moon)"
                               Color="Color.Inherit" OnClick="ToggleDarkMode" Size="Size.Small" />
            </MudTooltip>
        </div>

        <!-- Centered content -->
        <div class="auth-center">
            @Body
        </div>

    </div>
</MudRTLProvider>

<style>
    .auth-root {
        direction: rtl;
        font-family: "MV Typewriter", "Ak Rasmee", sans-serif;
        display: flex;
        flex-direction: column;
    }

    .auth-topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 16px 28px;
        direction: rtl;
    }

    .auth-center {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px 16px 60px;
        min-height: calc(100vh - 68px);
    }
</style>

@code {
    private bool _isDarkMode;
    private MudTheme _theme = new();

    protected override void OnInitialized()
    {
        _theme = new MudTheme
        {
            PaletteLight = new PaletteLight
            {
                Primary = "#594AE2",
                Background = "#f5f5f5",
                Surface = "#ffffff",
            },
            PaletteDark = new PaletteDark
            {
                Primary = "#776be7",
                Background = "#1e1e2d",
                Surface = "#26263a"
            },
            Typography = new Typography
            {
                Default = new DefaultTypography
                {
                    FontFamily = new[] { "MV Typewriter", "Ak Rasmee" }
                }
            }
        };
    }

    protected override async Task OnInitializedAsync()
    {
        _isDarkMode = await ThemePreferenceService.GetDarkModeAsync();
    }

    private async Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        await ThemePreferenceService.SetDarkModeAsync(_isDarkMode);
    }
}
