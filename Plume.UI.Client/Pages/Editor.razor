@page "/editor"
@implements IDisposable
@using System.Net.Http.Headers
@using System.Net.Http.Json
@using Contract.Requests.Articles
@using Contract.Responses.Articles
@using Contract.Common
@using Plume.UI.Client.Auth
@using Plume.UI.Client.Components
@using Plume.UI.Client.Models
@inject HttpClient Http
@inject IClientAuthService AuthService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<div id="title-field-wrapper" class="mb-4">
    <MudTextField @bind-Value="_title"
                  Label="ސުރުޙީ"
                  Margin="Margin.Dense"
                  Variant="Variant.Outlined"
                  id="title"
                  FullWidth="true"
                  dir="rtl" />
</div>

<div class="mb-4">
    <EditorJs @ref="_editorRef" Config="@_editorConfig" OnSavedJson="HandleSaved" />
</div>

<style>
    .mud-input-label-outlined {
        padding: 2px 5px !important;
    }
</style>
@code {

    private EditorJs? _editorRef;
    private DotNetObjectReference<Editor>? _dotNetRef;
    private string _title = string.Empty;
    private bool _isPublishing;
    private bool _isSaving;

    private EditorJsConfig _editorConfig = new();

    protected override void OnInitialized()
    {
        _editorConfig = new EditorJsConfig
        {
            Placeholder = "ކޮންމެވެސް މޮޅު ވާހަކަ އަކުން ފަށަމާ...",
            RightToLeft = true,
            Tools = new Dictionary<string, EditorToolConfig>
            {
                { "header", new EditorToolConfig { Class = "Header", InlineToolbar = true, Config = new { placeholder = "ސުރުހީ..." } } },
                { "list", new EditorToolConfig { Class = "EditorjsList", InlineToolbar = true } },
                { "quote", new EditorToolConfig { Class = "Quote", InlineToolbar = true } },
                { "linkTool", new EditorToolConfig { Class = "LinkTool", Config = new { endpoint = "/api/link/fetchUrl" } } },
                { "table", new EditorToolConfig { Class = "Table", InlineToolbar = true, Config = new { rows = 2, cols = 3 } } },
                { "code", new EditorToolConfig { Class = "CodeTool" } },
                { "image", new EditorToolConfig { Class = "SimpleImage" } },
                { "embed", new EditorToolConfig { Class = "EmbedTool", Config = new {
                    services = new {
                        youtube = new { height = 400, width = 600 }
                    }
                } } },
                { "fontFamily", new EditorToolConfig { Class = "FontFamily" } },
                { "fontSize", new EditorToolConfig { Class = "FontSize" } }
            },
            InlineToolbar = new[] { "fontFamily", "fontSize", "bold", "link", "marker", "italic" },
            I18n = new I18nConfig { Direction = "rtl" },
            Autofocus = true,
            Data = new {
                blocks = new object[] {
                    // new { type = "header", data = new { text = "", level = 2 } },
                    new { type = "paragraph", data = new { text = "" } }
                }
            }
        };
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("dhivehi.setupDhivehiInput", "title-field-wrapper", _dotNetRef);
        }
    }
    
    [JSInvokable]
    public void UpdateTitle(string value)
    {
        _title = value;
        StateHasChanged();
    }

    public void Dispose() => _dotNetRef?.Dispose();

    private async Task HandleSaved(string json)
    {
        if (string.IsNullOrWhiteSpace(_title))
        {
            Snackbar.Add("ސުރުހީ ލިޔުއްވާ.", Severity.Warning);
            _isPublishing = false;
            return;
        }

        _isSaving = true;
        StateHasChanged();

        try
        {
            var token = await AuthService.GetAccessTokenAsync();
            if (string.IsNullOrEmpty(token))
            {
                Snackbar.Add("ލޮގިން ވެލައްވާ.", Severity.Warning);
                return;
            }

            using var request = new HttpRequestMessage(HttpMethod.Post, "api/articles/me");
            request.Headers.Authorization = new AuthenticationHeaderValue("Bearer", token);
            request.Content = JsonContent.Create(new CreateArticleRequest
            {
                Title = _title,
                Content = json,
                Publish = _isPublishing
            });

            var httpResponse = await Http.SendAsync(request);
            var result = await httpResponse.Content.ReadFromJsonAsync<Response<ArticleResponse>>();

            if (result?.Success == true)
            {
                var message = _isPublishing ? "ލިޔުން ޝާއިއު ކުރެވިއްޖެ!" : "ލިޔުން ރައްކާ ކުރެވިއްޖެ!";
                Snackbar.Add(message, Severity.Success);
            }
            else
            {
                Snackbar.Add(result?.Message ?? "ލިޔުން ރައްކާ ކުރެވޭ ވަރެއް ނުވި.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSaving = false;
            _isPublishing = false;
            StateHasChanged();
        }
    }

}
