@page "/my-stories"
@using MudBlazor

<div class="my-stories-page">
    <MudText Typo="Typo.h4" GutterBottom="true" Style="font-weight: 800;">އަހަރެންގެ ލިޔުންތައް</MudText>

    <MudTabs Elevation="0" Rounded="true" PanelClass="mt-4">
        <MudTabPanel Text="ޑްރާފްޓްސް">
            <MudGrid>
                @for (int i = 1; i <= 3; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1);">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">ޑްރާފްޓް ލިޔުން @i</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">ތައްޔާރުކުރަމުން ދަނީ</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           Style="border-radius: 999px;">އިސްލާހުކުރައްވާ</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Success"
                                           Style="border-radius: 999px;">ޕަބްލިޝްކުރައްވާ</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error"
                                           Style="border-radius: 999px;">ފޮހެލައްވާ</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="ޝެޑިއުލްކުރެވިފައި">
            <MudGrid>
                @for (int i = 1; i <= 2; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1);">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">ޝެޑިއުލްކުރެވިފައިވާ ލިޔުން @i</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">ޕަބްލިޝްކުރާނެ ތާރީޚް: 25 ޖެނުއަރީ 2026</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           Style="border-radius: 999px;">އިސްލާހުކުރައްވާ</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Error"
                                           Style="border-radius: 999px;">ކެންސަލްކުރައްވާ</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="ޕަބްލިޝްކުރެވިފައި">
            <MudGrid>
                @for (int i = 1; i <= 5; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1);">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">ޕަބްލިޝްކުރެވިފައިވާ ލިޔުން @i</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">ޕަބްލިޝްކުރި ތާރީޚް: 20 ޖެނުއަރީ 2026</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           Style="border-radius: 999px;">ބައްލަވާ</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Warning"
                                           Style="border-radius: 999px;">އަންލިސްޓްކުރައްވާ</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>
        <MudTabPanel Text="އަންލިސްޓްކުރެވިފައި">
            <MudGrid>
                @for (int i = 1; i <= 1; i++)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1);">
                            <MudCardContent>
                                <MudText Typo="Typo.h6" Style="font-weight: 700;">އަންލިސްޓް ލިޔުން @i</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">އަންލިސްޓްކުރި ތާރީޚް: 18 ޖެނުއަރީ 2026</MudText>
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Text" Color="Color.Primary"
                                           Style="border-radius: 999px;">ބައްލަވާ</MudButton>
                                <MudButton Variant="Variant.Text" Color="Color.Success"
                                           Style="border-radius: 999px;">ޕަބްލިޝްކުރައްވާ</MudButton>
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        </MudTabPanel>
    </MudTabs>
</div>

