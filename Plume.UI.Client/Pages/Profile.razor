@page "/profile/{Username}"
@using MudBlazor

<div class="profile-page">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="10" md="10" lg="10">
            <MudPaper Class="pa-6" Elevation="0" Style="border-radius: 20px; border: 1px solid rgba(128,128,128,0.1);">
                <MudGrid>
                    <MudItem xs="12" sm="1">
                        <MudAvatar Color="Color.Primary" Size="Size.Large" Style="border-radius: 50%; width: 64px; height: 64px; font-size: 1.4rem;">
                            @GetInitials(Username)
                        </MudAvatar>
                    </MudItem>
                    <MudItem xs="12" sm="9">
                        <MudText Typo="Typo.h5" Style="font-weight: 800;">@Username</MudText>
                        <MudText Typo="Typo.body1" Style="opacity: 0.6;">@@@Username</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <MudTabs Class="mt-4" Elevation="0">
                <MudTabPanel Text="ލިޔުންތައް">
                    <MudStack Spacing="3" Class="mt-3">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <MudCard Elevation="0"
                                     Style="border-radius: 16px; border: 1px solid rgba(128,128,128,0.1);">
                                <MudCardContent>
                                    <MudText Typo="Typo.h6" Style="font-weight: 700;">ލިޔުން @i</MudText>
                                    <MudText Typo="Typo.body2" Class="mt-1" Style="opacity: 0.65;">
                                        މިއީ ލިޔުން @i ގެ ކޮންޓެންޓެވެ.
                                    </MudText>
                                </MudCardContent>
                                <MudCardActions>
                                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                                               Style="border-radius: 999px;">އިތުރަށް ކިޔުއްވާ</MudButton>
                                </MudCardActions>
                            </MudCard>
                        }
                    </MudStack>
                </MudTabPanel>
                <MudTabPanel Text="އޭނާގެ މައުލޫމާތު">
                    <MudText Class="mt-4">މިއީ @Username ގެ މައުލޫމާތު ހިމެނޭ ބައެވެ.</MudText>
                </MudTabPanel>
            </MudTabs>
        </MudItem>
    </MudGrid>
</div>

@code {
    [Parameter]
    public string? Username { get; set; }

    private string GetInitials(string? username)
    {
        if (string.IsNullOrEmpty(username))
            return "";
        return username.Length > 1 ? username.Substring(0, 1).ToUpper() : username.ToUpper();
    }
}