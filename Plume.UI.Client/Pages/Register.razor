@page "/register"
@inject IClientAuthService AuthService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>ރަޖިސްޓްރީ</PageTitle>

<MudGrid Justify="Justify.Center" Class="mt-16">
    <MudItem xs="12" sm="8" md="5">
        <MudPaper Class="pa-4" Elevation="3">
            <MudText Typo="Typo.h5" GutterBottom="true">ރަޖިސްޓްރީ ކުރައްވާ</MudText>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }

            @if (_errors.Any())
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    <ul>
                        @foreach (var error in _errors)
                        {
                            <li>@error</li>
                        }
                    </ul>
                </MudAlert>
            }

            <MudForm @ref="_form" @bind-IsValid="_isValid" Model="@_model">
                <MudTextField T="string"
                              Label="ޔޫޒާ ނަން"
                              @bind-Value="_model.Username"
                              For="@(() => _model.Username)"
                              Required="true"
                              RequiredError="ޔޫޒާ ނަން ބޭނުންވެއެވެ."
                              Disabled="_isLoading"
                              HelperText="3-100 އަކުރު" />

                <MudTextField T="string"
                              Label="ނަން (ޑިސްޕްލޭ)"
                              @bind-Value="_model.DisplayName"
                              For="@(() => _model.DisplayName)"
                              Disabled="_isLoading"
                              HelperText="އެހެން މީހުންނަށް ފެންނާނީ މި ނަން" />

                <MudTextField T="string"
                              Label="އީމެއިލް"
                              @bind-Value="_model.Email"
                              For="@(() => _model.Email)"
                              Required="true"
                              RequiredError="އީމެއިލް ބޭނުންވެއެވެ."
                              InputType="InputType.Email"
                              Disabled="_isLoading" />

                <MudTextField T="string"
                              Label="ޕާސްވޯޑް"
                              @bind-Value="_model.Password"
                              For="@(() => _model.Password)"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="ޕާސްވޯޑް ބޭނުންވެއެވެ."
                              Disabled="_isLoading"
                              HelperText="މަދުވެގެން 8 އަކުރު، ބޮޑު އަކުރެއް، ކުޑަ އަކުރެއް، ނަންބަރެއް" />

                <MudTextField T="string"
                              Label="ޕާސްވޯޑް ޔަޤީންކުރައްވާ"
                              @bind-Value="_model.ConfirmPassword"
                              For="@(() => _model.ConfirmPassword)"
                              InputType="InputType.Password"
                              Required="true"
                              RequiredError="ޕާސްވޯޑް ޔަޤީންކުރައްވާ."
                              Disabled="_isLoading" />

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="HandleRegister"
                           Disabled="@(!_isValid || _isLoading)"
                           Class="mt-4"
                           FullWidth="true">
                    @if (_isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    ރަޖިސްޓްރީ ކުރައްވާ
                </MudButton>
            </MudForm>

            <MudDivider Class="my-4" />

            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Custom.Brands.Google"
                       Color="Color.Default"
                       OnClick="RegisterWithGoogle"
                       FullWidth="true"
                       Disabled="_isLoading">
                ގޫގަލް އިން ރަޖިސްޓްރީ ކުރައްވާ
            </MudButton>

            <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center">
                އެކައުންޓެއް އެބައޮތްތޯ؟ <MudLink Href="/login">ސައިން-އިން ކުރައްވާ</MudLink>
            </MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudForm _form = null!;
    private bool _isValid;
    private bool _isLoading;
    private string? _errorMessage;
    private List<string> _errors = new();
    private readonly RegisterModel _model = new();

    private async Task HandleRegister()
    {
        await _form.Validate();
        if (!_form.IsValid) return;

        _isLoading = true;
        _errorMessage = null;
        _errors.Clear();

        try
        {
            var result = await AuthService.RegisterAsync(_model);

            if (result.Success)
            {
                Snackbar.Add("ރަޖިސްޓްރީ ކާމިޔާބު! ސައިން-އިން ކުރައްވާ.", Severity.Success);
                Navigation.NavigateTo("/login");
            }
            else
            {
                if (result.Errors?.Any() == true)
                {
                    _errors = result.Errors.ToList();
                }
                else
                {
                    _errorMessage = result.Error ?? "ރަޖިސްޓްރީ ފެއިލް ވެއްޖެ.";
                }
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"އެރާއެއް ދިމާވެއްޖެ: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void RegisterWithGoogle()
    {
        Navigation.NavigateTo("api/auth/google-login?redirectUrl=/", forceLoad: true);
    }
}
